# .env - Environment variables for the server
# These variables are loaded by dotenv and used throughout the application
# WHY: Keeps sensitive configuration separate from code and version control

# MongoDB connection string
# WHAT: URL to connect to MongoDB database
# WHY: Specifies database location and name
# HOW: localhost:27017 is MongoDB default port, shopping-cart is database name
MONGO_URI=mongodb://localhost:27017/shopping-cart

# Server port
# WHAT: Port number where the Express server will listen
# WHY: Allows configuration of server port (useful for deployment)
# HOW: Defaults to 5000 if not set
PORT=5000
